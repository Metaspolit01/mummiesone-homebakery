# Frontend runtime config (Vite exposes only VITE_* variables)
# Copy this file to .env and edit values.

# Phone number shown on website and used for tel: links (digits only)
VITE_PHONE_NUMBER=7013386529

# WhatsApp number in E.164 digits only (country code + number, no +)
# For India +91 7013386529 => 917013386529
VITE_WHATSAPP_NUMBER_E164=917013386529
